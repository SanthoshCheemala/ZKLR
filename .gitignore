# Generated/ignored files for ZKLR

# Compiled binaries (root-level only, not source dirs)
/batch_predict
/predict
/benchmark
/export

# Circuit cache and keys
*.cache
*.key
*.vk

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# Python
__pycache__/
*.py[cod]

# Editors/IDE
.vscode/
.idea/

# macOS
.DS_Store

# Logs and temp
*.log
*.tmp

# Secrets — never commit credentials
*.token
*.secret

# Exported proof artifacts (regenerated by -export-proofs)
results/proofs_*/

# EZKL working directory (large keys/witnesses; summary txt kept)
results/ezkl_baseline/

# Raw dataset downloads (re-fetched by scripts/prepare_real_datasets.py)
data/raw/

# Compiled HPC benchmark binaries (built by run_hpc_*.sh)
/bin/

# Foundry build outputs and deps
contracts/out/
contracts/cache/
contracts/lib/

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.lof
*.lot
*.toc
*.synctex
*.synctex.gz
*.tex.bak
